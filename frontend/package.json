{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "cd src/libs/compute && cargo fetch",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:vite": "vite",
    "dev:wasm": "yarn --cwd src/libs/compute build:wasm",
    "dev": "yarn dev:wasm && yarn dev:vite",
    "build:wasm": "yarn --cwd src/libs/compute build:wasm:release",
    "build": "yarn build:wasm && vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/three": "^0.183.1",
    "ant-design-vue": "^4.2.6",
    "echarts": "^6.0.0",
    "idb": "^8.0.3",
    "three": "^0.183.2",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "vitest": "^3.2.4",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13",
    "vue-tsc": "^3.1.5"
  },
  "resolutions": {
    "vite": "^8.0.0-beta.13"
  }
}
